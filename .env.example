CONSENSUS_CLIENT_URI=http://...
EXECUTION_CLIENT_URI=http://...
KEYS_API_URI=https://...
LIDO_LOCATOR_ADDRESS=0x1...

# For direct run (`docker run ... csm|cm`): use STAKING_MODULE_ADDRESS
STAKING_MODULE_ADDRESS=0x...

# For docker compose:
# - csm-oracle uses CS_MODULE_ADDRESS
# - cm-oracle uses CURATED_MODULE_ADDRESS
CS_MODULE_ADDRESS=0x...
CURATED_MODULE_ADDRESS=0x...

MEMBER_PRIV_KEY=aaa...
# Optional: separate account for telemetry; falls back to MEMBER_PRIV_KEY if not set
TELEMETRY_PRIV_KEY=...
PINATA_JWT=...
KUBO_HOST=...
